---
const year = new Date().getFullYear();
---
<footer class="bg-ink-900 py-10 border-t border-white/5">
  <div class="container-x">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 text-white/60 text-sm">
      <a href="/" class="flex items-center gap-2 text-white font-extrabold">
        <img src="/images/logo.svg" alt="" width="28" height="28" />
        DuoBrain
      </a>

      <nav class="flex flex-wrap items-center justify-center gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="/support" class="hover:text-white transition-colors">Support</a>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
      </nav>

      <p>© {year} DuoBrain. All rights reserved.</p>
    </div>
  </div>
</footer>
