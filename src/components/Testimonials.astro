<section class="py-20 sm:py-28 bg-white">
  <div class="container-x">
    <div class="eyebrow mb-10">What people are saying</div>

    <div class="grid lg:grid-cols-12 gap-5">
      <!-- Big dark testimonial -->
      <div class="lg:col-span-5 bg-ink text-white rounded-3xl p-8 sm:p-10 relative">
        <div class="absolute top-6 left-6 text-6xl text-white/10 font-serif leading-none">"</div>
