---
---
<section class="hero-bg relative overflow-hidden">
  <div class="container-x relative pt-12 pb-16 sm:pt-16 sm:pb-24 lg:pt-20 lg:pb-32">

    <!-- Grid: text left, phones right. Stacks on mobile. -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-8 items-center">

      <!-- TEXT -->
      <div class="lg:col-span-6 text-center lg:text-left">
        <span class="pill mb-6">Now on App Store · iOS</span>

        <h1 class="text-hero mb-6 text-balance">
          Don't just think<br />as a winner.<br />
          <span class="display-italic">Act like one.</span>
        </h1>

        <p class="text-base sm:text-lg text-muted max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
          DuoBrain trains the exact moments where careers are won or lost — meetings, pitches, negotiations, tough conversations. Real scenarios. AI feedback. 5 minutes a day.
        </p>

        <div class="flex justify-center lg:justify-start mb-8">
          <a href="#download" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
            Download on App Store
          </a>
        </div>

        <div class="flex items-center justify-center lg:justify-start gap-3 text-sm">
          <div class="flex gap-0.5 text-accent text-lg leading-none">★★★★★</div>
          <span class="text-ink"><strong>Best for</strong> <span class="text-muted">professionals · </span><strong>4.7/5</strong> <span class="text-muted">Score after Beta</span></span>
        </div>
      </div>

      <!-- PHONES -->
      <div class="lg:col-span-6 relative">
        <div class="relative max-w-[560px] mx-auto aspect-[5/4] phones-wrap">
          <!-- Back phone (left) — Listen and pick one option -->
          <img
            src="/images/phone-hero-scenario.webp"
            alt="Scenario selection in DuoBrain app"
            class="phone phone--left"
            loading="eager"
            width="688"
            height="1471"
          />
          <!-- Center phone (main) — Good job -->
          <img
            src="/images/phone-hero-score.webp"
            alt="Score and AI analysis in DuoBrain app"
            class="phone phone--center"
            loading="eager"
            width="930"
            height="2000"
          />
          <!-- Front phone (right) — Brain insights -->
          <img
            src="/images/phone-hero-insights.webp"
            alt="Brain insights in DuoBrain app"
            class="phone phone--right"
            loading="eager"
            width="688"
            height="1471"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .phones-wrap {
    /* Let the center phone breathe at the top a bit */
    padding-top: 2%;
  }

  .phone {
    position: absolute;
    /* Tight, dark, physical-looking shadow that follows the phone silhouette */
    filter:
      drop-shadow(0 24px 40px rgba(11, 34, 57, 0.22))
      drop-shadow(0 6px 12px rgba(11, 34, 57, 0.14));
    will-change: transform;
    transition: transform 0.4s ease;
  }

  /* Back-left phone: Listen and pick one option
     — sits LOW and LEFT, peeking out from behind the center */
  .phone--left {
    left: 2%;
    top: 18%;
    width: 36%;
    transform: rotate(-8deg);
    transform-origin: center bottom;
    z-index: 1;
  }

  /* Center hero phone: Good job!
     — NOT much bigger than the others, just frontmost and straight */
  .phone--center {
    left: 30%;
    top: 4%;
    width: 40%;
    transform: rotate(0deg);
    z-index: 3;
  }

  /* Back-right phone: Brain insights
     — mirror of the left phone, same height, same size */
  .phone--right {
    right: 2%;
    top: 18%;
    width: 36%;
    transform: rotate(8deg);
    transform-origin: center bottom;
    z-index: 2;
  }

  /* Subtle hover lift on desktop only */
  @media (hover: hover) and (min-width: 1024px) {
    .phones-wrap:hover .phone--left   { transform: rotate(-10deg) translateY(-4px); }
    .phones-wrap:hover .phone--center { transform: rotate(0deg)   translateY(-6px); }
    .phones-wrap:hover .phone--right  { transform: rotate(10deg)  translateY(-4px); }
  }

  /* Mobile tweak: soften shadows + slightly larger center */
  @media (max-width: 640px) {
    .phone--left   { width: 36%; top: 20%; left: 0; }
    .phone--center { width: 42%; top: 6%; }
    .phone--right  { width: 36%; top: 20%; right: 0; }
    .phone {
      filter:
        drop-shadow(0 14px 24px rgba(11, 34, 57, 0.20))
        drop-shadow(0 4px 8px rgba(11, 34, 57, 0.12));
    }
  }
</style>
