---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Blog — DuoBrain"
  description="Notes on communication, career, and building DuoBrain in public."
>
  <Header />
  <main class="py-16 sm:py-24">
    <div class="container-x max-w-3xl">
      <div class="mb-14">
        <div class="eyebrow mb-5">Blog</div>
        <h1 class="text-h2 text-balance mb-4">Notes from building DuoBrain.</h1>
        <p class="text-muted text-lg max-w-xl leading-relaxed">
          Honest writing on communication, career, and building a product while holding down a full-time job.
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-muted">No posts yet.</p>
      ) : (
        <ul class="divide-y divide-mist-200">
          {posts.map((post) => (
            <li class="py-8 first:pt-0">
              <a href={`/blog/${post.slug}/`} class="group block">
                <time datetime={post.data.publishDate.toISOString()} class="text-xs font-bold tracking-wider uppercase text-muted">
                  {formatDate(post.data.publishDate)}
                </time>
                <h2 class="text-2xl sm:text-3xl font-extrabold text-ink mt-2 mb-3 group-hover:text-ink-700 transition-colors text-balance">
                  {post.data.title}
                </h2>
                <p class="text-muted leading-relaxed">{post.data.description}</p>
                <span class="inline-block mt-4 text-sm font-bold text-ink group-hover:underline">Read more →</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
